  "publicApiSurface": [
    "BetterQuesting /bq_admin commands (edit, default load, default save, reset all)",
    "CraftTweaker recipe modification scripts",
    "GregTech configuration files (GregTech.cfg, WorldGeneration.cfg, Pollution.cfg)",
    "changelog.py CLI tool for generating version changelogs",
    "GitHub release workflow (release-tags.yml) producing versioned modpack ZIPs",
    "Quest internationalization workflow (questbook-i18n.yml) and lang file system",
    "servers.json community server list",
    "config/betterquesting/DefaultQuests quest data directory"
